  <script>
    (function() {
      const cursorGlow = document.getElementById('cursor-glow');
      if (cursorGlow) {
        document.addEventListener('mousemove', (e) => {
          cursorGlow.style.opacity = '1';
          cursorGlow.style.left = e.clientX + 'px';
          cursorGlow.style.top = e.clientY + 'px';
        });
        document.addEventListener('mouseleave', () => {
          cursorGlow.style.opacity = '0';
        });
      }

      const loadPopup = document.getElementById('loadPopup');
      const closePopup = document.getElementById('closePopup');
      const continueLink = document.getElementById('continueToSite');
      const openPopupBtn = document.getElementById('openPopupBtn');
      const stickyPopupBtn = document.getElementById('stickyPopupBtn');
      const bridgeStrategyBtn = document.getElementById('bridgeStrategyBtn');

      function showPopup() {
        loadPopup.classList.remove('hidden');
      }
      function hidePopup() {
        loadPopup.classList.add('hidden');
        sessionStorage.setItem('popupShown', 'true');
      }
      window.closePopupModal = hidePopup;

      if (closePopup) {
        closePopup.addEventListener('click', hidePopup);
        closePopup.addEventListener('touchstart', hidePopup, { passive: true });
      }
      if (continueLink) {
        continueLink.addEventListener('click', (e) => {
          e.preventDefault();
          hidePopup();
        });
      }
      const popupBackdrop = document.getElementById('popupBackdrop');
      if (popupBackdrop) {
        popupBackdrop.addEventListener('click', hidePopup);
        popupBackdrop.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); hidePopup(); } });
      }
      if (openPopupBtn) {
        openPopupBtn.addEventListener('click', (e) => {
          e.preventDefault();
          showPopup();
        });
      }
      if (stickyPopupBtn) {
        stickyPopupBtn.addEventListener('click', (e) => {
          e.preventDefault();
          showPopup();
        });
      }
      if (bridgeStrategyBtn) {
        bridgeStrategyBtn.addEventListener('click', (e) => {
          e.preventDefault();
          showPopup();
        });
      }

      if (!sessionStorage.getItem('popupShown')) {
        setTimeout(() => {
          showPopup();
        }, 2000);
      }

      const sticky = document.getElementById('stickyCta');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 600) {
          sticky.classList.add('show');
        } else {
          sticky.classList.remove('show');
        }
      });

      const urlParams = new URLSearchParams(window.location.search);
      const source = urlParams.get('source') || 'direct';

      const popupIframe = document.getElementById('popup-iframe');
      if (popupIframe) {
        let src = popupIframe.src;
        if (src.indexOf('?') === -1) {
          src += '?source=' + encodeURIComponent(source);
        } else {
          src += '&source=' + encodeURIComponent(source);
        }
        popupIframe.src = src;
      }
    })();
  </script>
